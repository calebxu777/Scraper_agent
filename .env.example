OPENAI_API_KEY=your_openai_key_here
USE_HANDYMAN=true
HANDYMAN_BACKEND=rules
HANDYMAN_MODEL=Qwen/Qwen2.5-0.5B-Instruct
HANDYMAN_DEVICE=cuda
HANDYMAN_DTYPE=auto
HANDYMAN_MAX_NEW_TOKENS=384
HANDYMAN_TEMPERATURE=0.0
USE_RULE_ROUTER=true
USE_HANDYMAN_VERIFY=true
API_MODEL=gpt-4o-mini
FETCH_BROWSER=playwright
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_WAIT_SELECTOR=a[href*="/product/"], .ais-Hits-item, [data-testid="product-card"]
MAX_CONCURRENCY=5
CRAWL_DB_PATH=crawl_state.db
